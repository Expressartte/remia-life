# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitas el .env con valores reales.

# OpenAI — clave para Whisper API
OPENAI_API_KEY=sk-...

# Google Gemini — clave para generateSocraticQuestions
GEMINI_API_KEY=AIza...

# (Alternativa) Si usas firebase functions:config en lugar de .env:
# firebase functions:config:set openai.key="sk-..." gemini.key="AIza..."
