# ─── Firebase Core ────────────────────────────────────────────────────────────
# Obtén estos valores desde: Firebase Console → Configuración del proyecto → Tus apps
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=remia-life.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=remia-life
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=remia-life.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Google Sign-In ───────────────────────────────────────────────────────────
# Obtén estos valores desde: Google Cloud Console → APIs y servicios → Credenciales
# iOS: Crea un "ID de cliente de OAuth 2.0" para iOS
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789-abc.apps.googleusercontent.com
# Android: Crea un "ID de cliente de OAuth 2.0" para Android
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=123456789-xyz.apps.googleusercontent.com
# Web: Crea un "ID de cliente de OAuth 2.0" para aplicación web
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-web.apps.googleusercontent.com
